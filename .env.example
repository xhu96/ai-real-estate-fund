DATABASE_URL=sqlite:///./data/app.db
CORS_ORIGINS=http://localhost:5173
ENABLE_DEMO_MODE=true

# Optional LLM analyst commentary. Set ONE provider key; LLM_PROVIDER overrides
# auto-detection (nvidia -> openai -> anthropic -> gemini).
NVIDIA_API_KEY=          # free key: https://build.nvidia.com
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
#LLM_PROVIDER=nvidia
#LLM_MODEL=meta/llama-3.1-8b-instruct  # fast/reliable default; meta/llama-3.3-70b-instruct for stronger analysis (slower cold start). Use Settings -> List models to browse the catalog.
#LLM_BASE_URL=https://integrate.api.nvidia.com/v1  # any OpenAI-compatible server
