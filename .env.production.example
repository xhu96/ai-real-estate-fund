APP_ENV=production
SERVICE_NAME=ai-real-estate-fund
APP_VERSION=0.6.0
RELEASE_SHA=replace-with-git-sha
SECRET_KEY=replace-with-32+-bytes-from-secret-manager
API_KEYS=operator:replace-with-random-api-key:read|write|analyze|export|admin
# Prefer API_KEY_HASHES in real deployments. Generate with scripts/rotate_api_key.py.
API_KEY_HASHES=
REQUIRE_API_KEY=true
REQUIRE_TLS=true
ENABLE_DEMO_MODE=false
ENABLE_FIXTURE_DATA=false
CORS_ORIGINS=https://app.ai-real-estate-fund.example
ALLOWED_HOSTS=api.ai-real-estate-fund.example
DATABASE_URL=sqlite:///./data/app.db
AUDIT_DATABASE_URL=sqlite:///./data/audit.db
ARTIFACT_ROOT=reports
DATA_ROOT=data
RATE_LIMIT_PER_MINUTE=120
MAX_PAYLOAD_BYTES=1000000
DATA_RETENTION_DAYS=365
AUDIT_RETENTION_DAYS=2555
JSON_LOGS=true
METRICS_ENABLED=true
MODEL_NAME=rules-v1
REQUIRE_HUMAN_APPROVAL_FOR_BUY=true
